[sub_resource type="GDScript" id="GDScript_85m7x"]
script/source = "extends Button

@export var event_scene:EventScene
@export var overview:DaemonOverview

var daemon:Daemon

func _ready() -> void:
	
	daemon = Global.get_random_daemon([2, 3, 5][Global.act])
	
	overview.daemon = daemon

func _pressed() -> void:
	PlayerData.permanent_daemons += [daemon]
	event_scene.event_finished.emit()
"

